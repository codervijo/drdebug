---
// src/layouts/FixLayout.astro
//
// Shared shell for the /fix/ programmatic-SEO section: base Layout + SEO head
// + a lightweight header/footer that match the landing page's design system.
// Page content goes in the default slot.
import Layout from "./Layout.astro";
import SeoHead from "../components/SeoHead.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  jsonLd?: unknown;
  noindex?: boolean;
}

const { title, description, canonical, jsonLd, noindex } = Astro.props;
---

<Layout>
  <Fragment slot="head">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      jsonLd={jsonLd}
      noindex={noindex}
    />
  </Fragment>

  <div class="min-h-screen bg-background text-foreground">
    <header class="sticky top-0 z-30 border-b border-border/60 bg-background/80 backdrop-blur">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
        <a href="/" class="flex items-center gap-2">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-primary-foreground">
            <!-- stethoscope glyph (matches lucide Stethoscope used on the landing page) -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 2v2"/><path d="M5 2v2"/><path d="M5 3H4a2 2 0 0 0-2 2v4a6 6 0 0 0 12 0V5a2 2 0 0 0-2-2h-1"/><path d="M8 15a6 6 0 0 0 12 0v-3"/><circle cx="20" cy="10" r="2"/></svg>
          </span>
          <span class="text-base font-semibold tracking-tight text-foreground">Doctor Debug</span>
        </a>
        <nav class="hidden items-center gap-7 text-sm text-muted-foreground md:flex">
          <a href="/fix/" class="transition hover:text-foreground">All fixes</a>
          <a href="/#how" class="transition hover:text-foreground">How it works</a>
        </nav>
        <a
          href="/#waitlist"
          class="inline-flex h-9 items-center justify-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground shadow-sm transition hover:bg-primary/90"
        >
          Join waitlist
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border bg-background">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-5 py-8 text-sm text-muted-foreground sm:flex-row sm:px-8">
        <p>Doctor Debug — plain-English fixes for broken AI agents.</p>
        <div class="flex items-center gap-5">
          <a href="/fix/" class="transition hover:text-foreground">All fixes</a>
          <a href="/" class="transition hover:text-foreground">Home</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>
