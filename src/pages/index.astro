---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import LandingPage from "../components/LandingPage.tsx";
import { FAQS } from "../lib/faq.ts";

const site = "https://drdebug.dev";
const title = "Doctor Debug — Plain-English fixes for broken AI agents";
// Meta description kept under ~155 chars for full SERP display.
const description =
  "Doctor Debug watches your no-code AI agents and turns cryptic failures into plain-English fixes — no logs, no guesswork, no engineer needed.";
const ogImage = `${site}/og-image.png`;

// JSON-LD graph: Organization + WebSite + SoftwareApplication (pre-launch)
// + FAQPage. FAQPage mirrors the visible FAQ section (both read src/lib/faq.ts)
// so structured data always matches on-page content.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site}/#organization`,
      name: "Doctor Debug",
      url: `${site}/`,
      logo: `${site}/favicon.svg`,
      // [VERIFY: add real social/GitHub profile URLs]
      sameAs: ["[VERIFY: add real social/GitHub profile URLs]"],
    },
    {
      "@type": "WebSite",
      "@id": `${site}/#website`,
      url: `${site}/`,
      name: "Doctor Debug",
      publisher: { "@id": `${site}/#organization` },
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${site}/#software`,
      name: "Doctor Debug",
      applicationCategory: "BusinessApplication",
      operatingSystem: "Web",
      url: `${site}/`,
      description:
        "Doctor Debug watches no-code AI agents on Lindy, Relay, n8n, Make, and Zapier and translates failures into plain-English fixes. Pre-launch — currently accepting waitlist signups.",
      publisher: { "@id": `${site}/#organization` },
    },
    {
      "@type": "FAQPage",
      "@id": `${site}/#faq`,
      mainEntity: FAQS.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    },
  ],
};
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="When your AI agent breaks, get a plain-English fix. Built for marketers, operators, consultants, and teams running AI agents without engineers."
    />
    <meta property="og:url" content={site} />
    <meta property="og:site_name" content="drdebug.dev" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: Organization + WebSite + SoftwareApplication + FAQPage.
         Built in the frontmatter above; FAQPage mirrors the visible FAQ. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <LandingPage client:load />
</Layout>
