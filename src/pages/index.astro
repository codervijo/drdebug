---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import LandingPage from "../components/LandingPage.tsx";

const site = "https://drdebug.dev";
const title = "Doctor Debug — Plain-English fixes for broken AI agents";
const description =
  "Doctor Debug watches your no-code AI agents, catches failures, and tells you exactly what went wrong — no logs, no guesswork, no developer translation needed.";
---

<Layout>
  <Fragment slot="head">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="When your AI agent breaks, get a plain-English fix. Built for marketers, operators, consultants, and teams running AI agents without engineers."
    />
    <meta property="og:url" content={site} />
    <meta property="og:site_name" content="drdebug.dev" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD structured data: Organization + WebSite (static; domain
         is known at scaffold time. Update description by hand if needed.) -->
    <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://drdebug.dev/#organization",
      "name": "Doctor Debug",
      "url": "https://drdebug.dev/"
    },
    {
      "@type": "WebSite",
      "@id": "https://drdebug.dev/#website",
      "url": "https://drdebug.dev/",
      "name": "Doctor Debug",
      "publisher": { "@id": "https://drdebug.dev/#organization" }
    }
  ]
}
    </script>
  </Fragment>

  <LandingPage client:load />
</Layout>
